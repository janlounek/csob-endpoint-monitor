<% var client = (typeof currentClient !== 'undefined') ? currentClient : null; %>
<%- include('header') %>

<div class="site-detail">
  <div class="site-header">
    <div>
      <p class="breadcrumb"><a href="/c/<%= client.slug %>">&larr; <%= client.name %> dashboard</a></p>
      <h1><%= site.name %></h1>
      <a href="<%= site.url %>" target="_blank" class="site-url"><%= site.url %></a>
    </div>
    <div class="site-actions">
      <button class="btn btn-primary" onclick="runSiteCheck(<%= site.id %>)">Check Now</button>
      <a href="/c/<%= client.slug %>/sites/<%= site.id %>/edit" class="btn btn-secondary">Edit</a>
      <button class="btn btn-danger" onclick="deleteSite(<%= site.id %>)">Delete</button>
    </div>
  </div>

  <h2>Current Status</h2>
  <div class="status-cards" id="status-cards">
    <p class="loading">Loading...</p>
  </div>

  <h2>Check History</h2>
  <table class="results-table" id="results-table">
    <thead>
      <tr>
        <th>Time</th>
        <th>Check</th>
        <th>Status</th>
        <th>Details</th>
      </tr>
    </thead>
    <tbody id="results-tbody">
      <tr><td colspan="4" class="loading">Loading...</td></tr>
    </tbody>
  </table>
  <button class="btn btn-secondary" id="load-more-btn" onclick="loadMoreResults()" style="display:none">Load More</button>
</div>

<script>
  var SITE_ID = <%= site.id %>;
  var CLIENT_SLUG = <%- JSON.stringify(client.slug) %>;
  var CHECKER_LABELS = <%- JSON.stringify(checkerLabels) %>;
  document.addEventListener('DOMContentLoaded', function() { loadSiteDetail(SITE_ID); });
</script>

<%- include('footer') %>
