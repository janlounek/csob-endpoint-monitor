<%- include('header') %>

<div class="settings-page">
  <h1>Global settings</h1>

  <form id="settings-form" onsubmit="saveSettings(event)">
    <div class="form-group">
      <label for="cron_schedule">Check schedule (cron expression)</label>
      <input type="text" id="cron_schedule" name="cron_schedule" placeholder="0 */4 * * *">
      <small class="help-text">Default: <code>0 */4 * * *</code> (every 4 hours). The scheduler checks all sites across all clients on this schedule. Slack webhooks are configured per client.</small>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Settings</button>
    </div>
  </form>

  <div id="settings-message"></div>
</div>

<script>document.addEventListener('DOMContentLoaded', function() { loadSettings(); });</script>

<%- include('footer') %>
